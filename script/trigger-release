#!/usr/bin/env bash
set -euo pipefail

if ! command -v gh >/dev/null 2>&1; then
    echo "Error: gh CLI is required. Install from https://cli.github.com/" >&2
    exit 1
fi

if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <stable|preview>"
    exit 1
fi

CHANNEL="$1"

if [ "$CHANNEL" == "nightly" ]; then
    echo "nightly releases are not supported in this template"
    exit 1
fi

version=$(script/get-crate-version app | sed 's/\.[^\.]*$/.x/')
echo "Bumping $CHANNEL (v$version)"

gh workflow run "bump_patch_version.yml" -f branch="v$version" -f channel="$CHANNEL"
echo "Follow along at: https://github.com/$(git remote get-url origin | sed 's/.*github.com[:/]//;s/.git$//')/actions"
